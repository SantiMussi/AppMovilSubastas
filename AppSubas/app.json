{
  "expo": {
    "name": "Vantage",
    "slug": "AppSubas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1528"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vantage.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B1528"
      },
      "package": "com.vantage.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1528",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita guardar la foto del DNI para validar tu identidad.",
          "cameraPermission": "La app necesita usar la cámara para tomar fotos del frente y dorso del DNI."
        }  
      ]
    ]
  }
}